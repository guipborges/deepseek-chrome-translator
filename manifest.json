{
  "manifest_version": 3,
  "name": "DeepSeek Text Translator",
  "description": "Translate selected text with DeepSeek API, save flashcards, and practice pronunciation.",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "windows"],
  "host_permissions": ["https://api.deepseek.com/*", "https://api.dictionaryapi.dev/*"],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "DeepSeek Translator",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
